<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web GIS Neraca Penatagunaan Tanah (Futuristic Cyber Dashboard)</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&family=Rajdhani:wght@500;600;700&display=swap');
        
        ::-webkit-scrollbar { width: 6px; hieght: 6px; }
        ::-webkit-scrollbar-track { background: #060b13; }
        ::-webkit-scrollbar-thumb { background: #0e3a41; border-radius: 3px; }
        #map { height: calc(100vh - 70px); }
        
        .cyber-panel {
            background: rgba(6, 15, 25, 0.85);
            backdrop-filter: blur(10px);
            border: 1px solid #00f3ff33;
            box-shadow: 0 0 15px rgba(0, 243, 255, 0.1);
        }
        
        .cyber-border-glow {
            box-shadow: 0 0 10px rgba(0, 243, 255, 0.2), inset 0 0 10px rgba(0, 243, 255, 0.1);
        }
        
        .text-neon-cyan {
            color: #00f3ff;
            text-shadow: 0 0 8px rgba(0, 243, 255, 0.6);
        }
        
        .text-neon-green {
            color: #39ff14;
            text-shadow: 0 0 8px rgba(57, 255, 20, 0.6);
        }
        
        .font-cyber {
            font-family: 'Rajdhani', sans-serif;
        }
        
        .font-orbitron {
            font-family: 'Orbitron', sans-serif;
        }

        /* Override Leaflet Dark Mode Style */
        .leaflet-container {
            background: #060b13 !important;
        }
        .leaflet-layer,
        .leaflet-control-zoom-in,
        .leaflet-control-zoom-out,
        .leaflet-popup-content-wrapper,
        .leaflet-popup-tip {
            filter: invert(100%) hue-rotate(180deg) brightness(95%) contrast(90%);
        }
    </style>
</head>
<body class="bg-[#03070d] text-gray-200 font-sans overflow-hidden font-cyber selection:bg-cyan-500 selection:text-black">

    <header class="bg-[#060b13]/90 border-b border-cyan-500/30 h-[70px] flex items-center justify-between px-4 md:px-6 shadow-[0_4px_20px_rgba(0,243,255,0.15)] z-50 relative">
        <div class="flex items-center space-x-3 md:space-x-4 pl-12 md:pl-0">
            <div class="p-1 bg-cyan-950/50 border border-cyan-500/30 rounded">
                <img src="logo-bpn.png" alt="Logo ATR/BPN" class="h-10 md:h-12 w-auto object-contain brightness-110 contrast-125" onerror="this.src='https://via.placeholder.com/50?text=BPN'">
            </div>
            <div>
                <h1 class="text-lg md:text-xl font-bold tracking-wider text-neon-cyan font-orbitron leading-tight">WEBGIS INTERAKTIF NPGT</h1>
                <p class="text-[10px] md:text-xs text-emerald-400 font-semibold tracking-widest">NERACA PENATAGUNAAN TANAH KECAMATAN WP3WT</p>
            </div>
        </div>
        <div class="hidden sm:block text-xs font-orbitron bg-cyan-950/40 px-3 py-1.5 rounded-md border border-cyan-500/40 text-cyan-400 shadow-[0_0_10px_rgba(0,243,255,0.2)]">
            SYS STATUS: <span class="text-neon-green animate-pulse">ACTIVE // v1.5</span>
        </div>
    </header>

    <button id="menuBtn" class="fixed top-[15px] left-4 z-[100] bg-cyan-950/80 hover:bg-cyan-900 text-cyan-400 p-2.5 rounded-xl border border-cyan-500 shadow-[0_0_15px_rgba(0,243,255,0.4)] flex items-center justify-center transition-all duration-300 focus:outline-none md:hidden">
        <svg id="menuIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        <svg id="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

    <div class="flex h-[calc(100vh-70px)] w-full relative">
        
        <aside id="sidebar" class="absolute md:relative top-0 left-0 h-full w-85 bg-[#040912]/95 border-r border-cyan-500/20 flex flex-col justify-between z-40 shadow-[5px_0_25px_rgba(0,0,0,0.8)] transition-all duration-300 transform -translate-x-full md:translate-x-0 w-80">
            <div class="p-5 overflow-y-auto flex-1 mt-12 md:mt-0 space-y-6">
                <div>
                    <h2 class="text-sm font-bold uppercase tracking-widest text-cyan-400 font-orbitron flex items-center gap-2">
                        <span class="inline-block w-2 h-2 bg-cyan-400 shadow-[0_0_8px_#00f3ff] animate-ping rounded-full"></span> DATA SPASIAL OVERLAY
                    </h2>
                    <p class="text-xs text-gray-400 mt-1">Aktifkan lapisan matriks untuk menyelaraskan visualisasi peta:</p>
                </div>

                <div class="space-y-2.5">
                    <label class="flex items-center justify-between p-3 bg-cyan-950/20 hover:bg-cyan-900/40 border border-cyan-500/20 hover:border-cyan-400/50 rounded-xl cursor-pointer transition group">
                        <span class="text-sm font-medium tracking-wide group-hover:text-cyan-300 transition">Penggunaan Tanah</span>
                        <input type="checkbox" id="layer1" class="w-4 h-4 text-cyan-500 rounded bg-gray-900 border-cyan-500/50 focus:ring-cyan-500 accent-cyan-500">
                    </label>

                    <label class="flex items-center justify-between p-3 bg-cyan-950/20 hover:bg-cyan-900/40 border border-cyan-500/20 hover:border-cyan-400/50 rounded-xl cursor-pointer transition group">
                        <span class="text-sm font-medium tracking-wide group-hover:text-cyan-300 transition">Ketersediaan Tanah</span>
                        <input type="checkbox" id="layer2" class="w-4 h-4 text-cyan-500 rounded bg-gray-900 border-cyan-500/50 focus:ring-cyan-500 accent-cyan-500">
                    </label>

                    <label class="flex items-center justify-between p-3 bg-cyan-950/20 hover:bg-cyan-900/40 border border-cyan-500/20 hover:border-cyan-400/50 rounded-xl cursor-pointer transition group">
                        <span class="text-sm font-medium tracking-wide group-hover:text-cyan-300 transition">Kesesuaian Pola Ruang</span>
                        <input type="checkbox" id="layer3" class="w-4 h-4 text-cyan-500 rounded bg-gray-900 border-cyan-500/50 focus:ring-cyan-500 accent-cyan-500">
                    </label>

                    <label class="flex items-center justify-between p-3 bg-cyan-950/20 hover:bg-cyan-900/40 border border-cyan-500/20 hover:border-cyan-400/50 rounded-xl cursor-pointer transition group">
                        <span class="text-sm font-medium tracking-wide group-hover:text-cyan-300 transition">Tekstur Tanah</span>
                        <input type="checkbox" id="layer4" class="w-4 h-4 text-cyan-500 rounded bg-gray-900 border-cyan-500/50 focus:ring-cyan-500 accent-cyan-500">
                    </label>

                    <label class="flex items-center justify-between p-3 bg-cyan-950/20 hover:bg-cyan-900/40 border border-cyan-500/20 hover:border-cyan-400/50 rounded-xl cursor-pointer transition group">
                        <span class="text-sm font-medium tracking-wide group-hover:text-cyan-300 transition">Kedalaman Efektif</span>
                        <input type="checkbox" id="layer5" class="w-4 h-4 text-cyan-500 rounded bg-gray-900 border-cyan-500/50 focus:ring-cyan-500 accent-cyan-500">
                    </label>

                    <label class="flex items-center justify-between p-3 bg-cyan-950/20 hover:bg-cyan-900/40 border border-cyan-500/20 hover:border-cyan-400/50 rounded-xl cursor-pointer transition group">
                        <span class="text-sm font-medium tracking-wide group-hover:text-cyan-300 transition">Tingkat Erosi</span>
                        <input type="checkbox" id="layer6" class="w-4 h-4 text-cyan-500 rounded bg-gray-900 border-cyan-500/50 focus:ring-cyan-500 accent-cyan-500">
                    </label>

                    <label class="flex items-center justify-between p-3 bg-cyan-950/20 hover:bg-cyan-900/40 border border-cyan-500/20 hover:border-cyan-400/50 rounded-xl cursor-pointer transition group">
                        <span class="text-sm font-medium tracking-wide group-hover:text-cyan-300 transition">Tingkat Drainase</span>
                        <input type="checkbox" id="layer7" class="w-4 h-4 text-cyan-500 rounded bg-gray-900 border-cyan-500/50 focus:ring-cyan-500 accent-cyan-500">
                    </label>
                </div>

                <div class="border-t border-cyan-500/20 pt-4">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-cyan-400 font-orbitron mb-3 flex items-center gap-1.5">
                        <span class="w-1.5 h-3 bg-cyan-500 inline-block"></span> KELAS ATRIBUT MATRIKS
                    </h3>
                    <div id="dynamicLegend" class="text-xs space-y-4 text-gray-300 bg-[#02050a]/80 p-3 rounded-xl border border-cyan-500/20 max-h-[220px] overflow-y-auto cyber-border-glow">
                        <p class="text-cyan-600/70 italic font-mono">[Awaiting telemetry... Silakan aktifkan layer]</p>
                    </div>
                </div>
            </div>

            <div class="p-4 bg-[#02050a] border-t border-cyan-500/20 text-center text-[11px] tracking-wider text-cyan-600/80 font-mono">
                KANWIL BPN PROVINSI GORONTALO // © 2026
            </div>
        </aside>

        <main id="map" class="flex-1 z-10 w-full relative">
            <!-- Simulated futuristic corner crosshairs like the image -->
            <div class="absolute top-4 left-4 w-4 h-4 border-t-2 border-l-2 border-cyan-500/40 pointer-events-none z-30"></div>
            <div class="absolute top-4 right-4 w-4 h-4 border-t-2 border-r-2 border-cyan-500/40 pointer-events-none z-30"></div>
            <div class="absolute bottom-4 left-4 w-4 h-4 border-b-2 border-l-2 border-cyan-500/40 pointer-events-none z-30"></div>
            <div class="absolute bottom-4 right-4 w-4 h-4 border-b-2 border-r-2 border-cyan-500/40 pointer-events-none z-30"></div>
        </main>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://api.mapbox.com/mapbox.js/plugins/leaflet-omnivore/v0.3.1/leaflet-omnivore.min.js"></script>

    <script>
        // --- LOGIKA TAMPILAN SIDEBAR ---
        const menuBtn = document.getElementById('menuBtn');
        const sidebar = document.getElementById('sidebar');
        const menuIcon = document.getElementById('menuIcon');
        const closeIcon = document.getElementById('closeIcon');

        menuBtn.addEventListener('click', () => {
            const isHidden = sidebar.classList.contains('-translate-x-full');
            sidebar.classList.toggle('-translate-x-full', !isHidden);
            menuIcon.classList.toggle('hidden', isHidden);
            closeIcon.classList.toggle('hidden', !isHidden);
        });

        document.getElementById('map').addEventListener('click', () => {
            if (window.innerWidth < 768) {
                sidebar.classList.add('-translate-x-full');
                menuIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
            }
        });

        // --- DEKLARASI PETA LEAFLET ---
        const map = L.map('map', { zoomControl: false }).setView([0.5435, 121.9324], 11);
        L.control.zoom({ position: 'topright' }).addTo(map);

        // Cyber map representation using high contrast map dark styling
        const basemaps = {
            "Cyber Satellite": L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { 
                attribution: 'Esri Satellites' 
            }),
            "Vector Network": L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{y}/{x}{r}.png', {
                attribution: 'CartoDB DarkMatter'
            })
        };
        basemaps["Vector Network"].addTo(map);
        L.control.layers(basemaps, null, { position: 'bottomright' }).addTo(map);

        // --- STRUKTUR WARNA STANDAR QGIS MODIFIKASI CYBER GLOW ---
        const skemaWarna = {
            tekstur: {
                'halus': '#00ffc4',       
                'sedang': '#00bfff',      
                'agak kasar': '#ff8800',  
                'kasar': '#ff0055'        
            },
            erosi: {
                'tidak ada erosi': '#00ffc4', 
                'erosi ringan': '#e5ff00',    
                'erosi sangat berat': '#ff0055' 
            },
            drainase: {
                'tidak pernah tergenang': '#008b8b', 
                'tergenang periodik': '#ffcc00',     
                'tergenang terus menerus': '#ff0055' 
            },
            kedalaman: {
                '30-50 cm': '#ff0055',
                '50-60 cm': '#ff7700',
                '60-75 cm': '#eedd00',
                '75-90 cm': '#00bfff',
                '90-150 cm': '#00ffaa'
            },
            penggunaan: {
                'sawah': '#00cc77', 'permukiman': '#ff3366', 'hutan': '#005533', 
                'kebun': '#aacc22', 'ladang': '#ccff33', 'tambak': '#0099ff', 'air': '#00ffff'
            },
            ketersediaan: {
                'tersedia': '#39ff14', 'terbatas': '#ffaa00', 'tidak tersedia': '#ff0055'
            },
            kesesuaian: {
                'sesuai': '#00f3ff', 'tidak sesuai': '#dd0044', 'sesuai bersyarat': '#ff6600'
            }
        };

        // --- ENGINE FILTER EVALUASI NILAI ATRIBUT FIELD ---
        function tentukanWarnaLayer(properties, idLayer) {
            const nameVal = (properties.name || "").toLowerCase().trim();
            const descVal = (properties.description || "").toLowerCase().trim();
            
            const txt = (properties.TEKSTUR || "").toLowerCase().trim();
            const ers = (properties.EROSI || "").toLowerCase().trim();
            const drn = (properties.DRAINS || "").toLowerCase().trim();
            const kdf = (properties.KDEFEK || "").toLowerCase().trim();

            if (idLayer === 'layer4') { 
                if (nameVal.includes('halus') || txt.includes('halus') || descVal.includes('halus')) return skemaWarna.tekstur['halus'];
                if (nameVal.includes('sedang') || txt.includes('sedang') || descVal.includes('sedang')) return skemaWarna.tekstur['sedang'];
                if (nameVal.includes('agak kasar') || txt.includes('agak kasar') || descVal.includes('agak kasar')) return skemaWarna.tekstur['agak kasar'];
                if (nameVal.includes('kasar') || txt.includes('kasar') || descVal.includes('kasar')) return skemaWarna.tekstur['kasar'];
            }
            if (idLayer === 'layer6') { 
                if (nameVal.includes('tidak ada') || ers.includes('tidak') || descVal.includes('tidak ada')) return skemaWarna.erosi['tidak ada erosi'];
                if (nameVal.includes('ringan') || ers.includes('ringan') || descVal.includes('ringan')) return skemaWarna.erosi['erosi ringan'];
                if (nameVal.includes('sangat berat') || ers.includes('berat') || descVal.includes('sangat berat')) return skemaWarna.erosi['erosi sangat berat'];
            }
            if (idLayer === 'layer7') { 
                if (nameVal.includes('tidak pernah') || drn.includes('tidak') || descVal.includes('tidak pernah')) return skemaWarna.drainase['tidak pernah tergenang'];
                if (nameVal.includes('periodik') || drn.includes('periodik') || descVal.includes('periodik')) return skemaWarna.drainase['tergenang periodik'];
                if (nameVal.includes('terus menerus') || drn.includes('terus') || descVal.includes('terus menerus')) return skemaWarna.drainase['tergenang terus menerus'];
            }
            if (idLayer === 'layer5') { 
                for (let key in skemaWarna.kedalaman) {
                    if (nameVal.includes(key) || kdf.includes(key) || descVal.includes(key)) return skemaWarna.kedalaman[key];
                }
            }
            if (idLayer === 'layer2') {
                if (nameVal.includes('tidak') || descVal.includes('tidak')) return skemaWarna.ketersediaan['tidak tersedia'];
                if (nameVal.includes('terbatas') || descVal.includes('terbatas')) return skemaWarna.ketersediaan['terbatas'];
                return skemaWarna.ketersediaan['tersedia'];
            }
            if (idLayer === 'layer3') {
                if (nameVal.includes('tidak') || descVal.includes('tidak')) return skemaWarna.kesesuaian['tidak sesuai'];
                if (nameVal.includes('bersyarat') || descVal.includes('bersyarat')) return skemaWarna.kesesuaian['sesuai bersyarat'];
                return skemaWarna.kesesuaian['sesuai'];
            }
            
            for (let key in skemaWarna.penggunaan) {
                if (nameVal.includes(key) || descVal.includes(key)) return skemaWarna.penggunaan[key];
            }
            return '#00ffc4'; 
        }

        // --- UPDATE PANEL BOX LEGENDA ---
        const activeLayersForLegend = {};
        function perbaruiHtmlLegenda() {
            const container = document.getElementById('dynamicLegend');
            container.innerHTML = '';
            let adaLayerAktif = false;
            
            const susunanJudul = {
                'layer1': 'Penggunaan Tanah', 'layer2': 'Ketersediaan Tanah', 'layer3': 'Kesesuaian RTRW',
                'layer4': 'Tekstur Tanah (TEKSTUR)', 'layer5': 'Kedalaman Efektif (KDEFEK)', 
                'layer6': 'Tingkat Erosi (EROSI)', 'layer7': 'Tingkat Drainase (DRAINS)'
            };

            for (let id in activeLayersForLegend) {
                if (activeLayersForLegend[id]) {
                    adaLayerAktif = true;
                    let htmlGrup = `<div class='mb-4 font-mono'><p class='font-bold text-cyan-400 border-b border-cyan-500/30 pb-1 mb-2 uppercase tracking-wider text-[11px]'>// ${susunanJudul[id]}</p><div class='space-y-1.5 pl-1'>`;
                    
                    let targetSkema = {};
                    if(id === 'layer4') targetSkema = skemaWarna.tekstur;
                    else if(id === 'layer5') targetSkema = skemaWarna.kedalaman;
                    else if(id === 'layer6') targetSkema = skemaWarna.erosi;
                    else if(id === 'layer7') targetSkema = skemaWarna.drainase;
                    else if(id === 'layer2') targetSkema = skemaWarna.ketersediaan;
                    else if(id === 'layer3') targetSkema = skemaWarna.kesesuaian;
                    else targetSkema = skemaWarna.penggunaan;

                    for(let label in targetSkema) {
                        htmlGrup += `<div class='flex items-center gap-2.5'><span class='w-3 h-3 rounded-xs border border-white/30 inline-block shadow-[0_0_6px_rgba(255,255,255,0.2)]' style='background-color:${targetSkema[label]}'></span><span class='capitalize text-gray-300 text-[11px]'>${label}</span></div>`;
                    }
                    htmlGrup += `</div></div>`;
                    container.innerHTML += htmlGrup;
                }
            }
            
            if (!adaLayerAktif) {
                container.innerHTML = '<p class="text-cyan-600/70 italic font-mono">[Awaiting telemetry... Silakan aktifkan layer]</p>';
            }
        }

        // --- BERSIHKAN TABEL POPUP ATRIBUT (CYBERTHEME) ---
        function customPopup(feature, layer) {
            if (feature.properties) {
                let content = "<div class='text-cyan-400 font-mono p-2 bg-[#050c14] border border-cyan-500/40 rounded shadow-2xl'><h3 class='font-bold border-b border-cyan-500/30 pb-1 mb-2 text-neon-cyan text-xs tracking-wider'>// CORE DATA TELEMETRY</h3><table class='text-[10px] w-full text-gray-300'>";
                for (let key in feature.properties) {
                    if(!['styleUrl', 'styleHash', 'id', 'fill', 'stroke', 'visibility', 'altitudeMode', 'tessellate', 'extrude', 'drawOrder', 'icon', 'snippet'].includes(key)) {
                        let val = feature.properties[key] || "-";
                        content += `<tr><td class='font-semibold text-cyan-500 pr-3 py-1 uppercase tracking-tight'>${key}</td><td class='text-gray-200 border-b border-cyan-950/40 py-1'>: ${val}</td></tr>`;
                    }
                }
                content += "</table></div>";
                layer.bindPopup(content);
            }
        }

        // --- FUNGSI UTAMA RECURSIVE OVERRIDE WARNA POLIGON ---
        function paksaWarnaPoligon(layerGroup, idLayer) {
            layerGroup.eachLayer(function(subLayer) {
                if (typeof subLayer.setStyle === 'function') {
                    subLayer.setStyle({
                        fillColor: tentukanWarnaLayer(subLayer.feature.properties, idLayer),
                        color: '#00f3ff',
                        weight: 1.0,
                        fillOpacity: 0.65
                    });
                } 
                if (typeof subLayer.eachLayer === 'function') {
                    paksaWarnaPoligon(subLayer, idLayer);
                }
            });
        }

        // --- MEMBACA DAN MEMPROSES BERKAS KMZ ---
        const loadedLayers = {};
        async function muatKmz(idLayer, urlFile) {
            try {
                const response = await fetch(urlFile);
                const blob = await response.blob();
                const zip = await JSZip.loadAsync(blob);
                
                const kmlFile = Object.keys(zip.files).find(name => name.endsWith('.kml'));
                if (!kmlFile) return;
                
                const kmlText = await zip.files[kmlFile].async("string");
                const parser = new DOMParser();
                const kmlDoc = parser.parseFromString(kmlText, "text/xml");
                
                const layerGeospasial = omnivore.kml.parse(kmlDoc, null, L.geoJson(null, {
                    onEachFeature: customPopup
                }));

                layerGeospasial.on('ready', function() {
                    paksaWarnaPoligon(layerGeospasial, idLayer);
                });

                loadedLayers[idLayer] = layerGeospasial;

                document.getElementById(idLayer).addEventListener('change', function (e) {
                    if (e.target.checked) {
                        loadedLayers[idLayer].addTo(map);
                        map.fitBounds(loadedLayers[idLayer].getBounds());
                        activeLayersForLegend[idLayer] = true;
                        
                        paksaWarnaPoligon(loadedLayers[idLayer], idLayer);

                        if (window.innerWidth < 768) sidebar.classList.add('-translate-x-full');
                    } else {
                        map.removeLayer(loadedLayers[idLayer]);
                        activeLayersForLegend[idLayer] = false;
                    }
                    
                    perbaruiHtmlLegenda();
                });

            } catch (error) {
                console.error(`Gagal memproses file KMZ (${urlFile}):`, error);
            }
        }

        // --- MENJALANKAN KESELURUHAN DATA AKTIF ---
        muatKmz('layer1', 'data/penggunaan_tanah.kmz');
        muatKmz('layer2', 'data/ketersediaan_tanah.kmz');
        muatKmz('layer3', 'data/kesesuaian_rtrw.kmz');
        muatKmz('layer4', 'data/tekstur_tanah.kmz');
        muatKmz('layer5', 'data/kedalaman_efektif.kmz');
        muatKmz('layer6', 'data/tingkat_erosi.kmz');
        muatKmz('layer7', 'data/tingkat_drainase.kmz');

    </script>
</body>
</html>
